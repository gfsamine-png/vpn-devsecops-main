# ─── Réseau ───────────────────────────────────────────────────
port {{ openvpn_port }}
proto {{ openvpn_proto }}
dev tun

# ─── Certificats ──────────────────────────────────────────────
ca   /etc/openvpn/server/ca.crt
cert /etc/openvpn/server/vpnserver.crt
key  /etc/openvpn/server/vpnserver.key
dh   /etc/openvpn/server/dh.pem

# ─── Authentification TLS ─────────────────────────────────────
tls-crypt /etc/openvpn/server/ta.key
tls-version-min 1.2

# ─── Cryptographie ────────────────────────────────────────────
data-ciphers {{ openvpn_cipher }}
auth {{ openvpn_auth }}

# ─── Réseau tunnel ────────────────────────────────────────────
server {{ openvpn_network }} {{ openvpn_netmask }}
ifconfig-pool-persist /var/log/openvpn/ipp.txt

# ─── Routage ──────────────────────────────────────────────────
push "route {{ lan_network }} {{ lan_netmask }}"

# ─── Sécurité ─────────────────────────────────────────────────
keepalive 10 120
user nobody
group nogroup
persist-key
persist-tun

# ─── Journalisation ───────────────────────────────────────────
status /var/log/openvpn/openvpn-status.log
log-append /var/log/openvpn/openvpn.log
verb {{ openvpn_verbosity }}
